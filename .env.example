# ==========================================
# VARIÁVEIS DE AMBIENTE - VITALIDADE 40+
# ==========================================

# AMBIENTE
NODE_ENV=development
PORT=3000

# ==========================================
# API KEYS - AI PROVIDERS
# ==========================================

# Google Gemini API
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI API
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq API (Llama)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=

# ==========================================
# BANCO DE DADOS - SUPABASE
# ==========================================

# Obtenha em: https://supabase.com
# Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ==========================================
# MONITORAMENTO E ANALYTICS
# ==========================================

# Sentry - Error Tracking
# Obtenha em: https://sentry.io
SENTRY_DSN=

# Vercel Analytics - Performance Monitoring
# Ativado automaticamente em Vercel
VERCEL_ANALYTICS_ID=

# ==========================================
# SEGURANÇA
# ==========================================

# JWT Secret para autenticação
# ⚠️ MUDE ISSO EM PRODUÇÃO! Use um valor aleatório forte:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev-secret-change-in-production-please

# CORS Origins (separado por vírgula)
# Desenvolvimento: *
# Produção: https://seu-dominio.com,https://www.seu-dominio.com
CORS_ORIGIN=*

# ==========================================
# DEPLOYMENT
# ==========================================

# URL da aplicação (para links de callback)
APP_URL=http://localhost:3000

# Slack Webhook (opcional - para notificações do CI/CD)
# SLACK_WEBHOOK=https://hooks.slack.com/services/...

# ==========================================
# TOKENS DE DEPLOY (CI/CD)
# ==========================================

# Vercel Deploy Token (para GitHub Actions)
# VERCEL_TOKEN=seu-token-aqui

# GitHub Token (para ações do workflow)
# GITHUB_TOKEN=seu-token-aqui
